# ============================================================
# 面向能源可信数据空间 - 环境变量配置模板
# 复制此文件为 .env 并修改为实际值
# ============================================================

# ==================== 应用配置 ====================

# 应用名称
APP_NAME=EnergyTrustedDataSpace

# 运行环境: development/staging/production
APP_ENV=development

# 调试模式 (true/false)
APP_DEBUG=true

# 应用密钥 (生产环境必须修改)
APP_SECRET_KEY=change-me-to-a-random-secret-key

# 监听地址
APP_HOST=0.0.0.0

# 监听端口
APP_PORT=8000

# ==================== 数据库配置 ====================

# PostgreSQL 配置
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=energy_tds
POSTGRES_USER=energy_admin
POSTGRES_PASSWORD=changeme_pg_password

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0

# MongoDB 配置
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=energy_tds_meta
MONGO_USER=energy_mongo
MONGO_PASSWORD=changeme_mongo_password

# ==================== 存储配置 ====================

# MinIO 对象存储配置
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=energy_minio_access
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET=energy-tds
MINIO_USE_SSL=false

# ==================== 消息队列配置 ====================

# MQTT Broker 配置 (EMQX)
MQTT_BROKER=tcp://emqx:1883
MQTT_WS_URL=ws://emqx:8083/mqtt
MQTT_CLIENT_ID=energy-tds-backend
MQTT_USERNAME=energy_mqtt
MQTT_PASSWORD=changeme_mqtt_password

# RabbitMQ 配置
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=energy_rabbit
RABBITMQ_PASSWORD=changeme_rabbit_password
RABBITMQ_VHOST=energy_tds

# ==================== 区块链配置 ====================

# FISCO BCOS 配置
FISCO_CHANNEL_HOST=fisco-node0
FISCO_CHANNEL_PORT=20200
FISCO_GROUP_ID=1
FISCO_CERT_PATH=/app/certs/fisco
FISCO_SM_CRYPTO=true

# ==================== 隐私计算配置 ====================

# FATE 配置
FATE_COORDINATOR_HOST=fate-coordinator
FATE_COORDINATOR_PORT=9380
FATE_PARTY_ID=10000

# MPSpdz 配置
MPSpdz_PARTY0_HOST=mpspdz-party0
MPSpdz_PARTY1_HOST=mpspdz-party1
MPSpdz_PARTY2_HOST=mpspdz-party2

# ==================== 安全配置 ====================

# JWT 配置
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# SM2 国密配置
SM2_PRIVATE_KEY_PATH=/app/certs/sm2/sm2_private_key.pem
SM2_PUBLIC_KEY_PATH=/app/certs/sm2/sm2_public_key.pem
SM2_CERT_PATH=/app/certs/sm2/sm2_cert.pem

# ==================== 监控配置 ====================

# Prometheus 配置
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090

# Grafana 配置
GRAFANA_HOST=grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme_grafana_admin

# ==================== AI 配置 ====================

# DeepSeek AI 配置
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ==================== 其他配置 ====================

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 工作进程数 (0 表示自动检测 CPU 核心数)
WORKERS=0

# 超时配置 (秒)
TIMEOUT=120
